{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/registrar",
      "dest": "app.js"
    },
    {
      "src": "/login",
      "dest": "app.js"
    },
    {
      "src": "/usuarios",
      "dest": "app.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}